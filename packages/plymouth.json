{
  "Flatpak": [],
  "Packages": [
    "plymouth"
  ],
  "Commands": [
    "sudo sed -i '/^HOOKS=/ s/udev/udev plymouth/' /etc/mkinitcpio.conf",
    "sudo mkinitcpio -P",
    "sudo sed -i 's/ quiet splash//g' /boot/refind_linux.conf",
    "sudo sed -i -E 's/(root=[^ ]*)/\\1 quiet splash/g' /boot/refind_linux.conf",
    "sudo plymouth-set-default-theme -R bgrt"
  ]
}
