#Api2

Set ThicknessHint = "20px"

PopUp "tray_popup" {
  AutoClose = true
  tray {
    rows = 1
  }
}

bar {
  edge = "bottom" 
  layer = "top"
  exclusive_zone = "auto"

  taskbar {
    style = "taskbar"
    rows = 1;
    tooltips = true;
    icons = true;
    labels = true;
    action[Drag] = Focus();
  }

  label {
    css = "* { -GtkWidget-hexpand: true; }"
  }

  button {
    label = "^"
    action = PopUp("tray_popup")
  }
}

#CSS
@import url("style.css");
