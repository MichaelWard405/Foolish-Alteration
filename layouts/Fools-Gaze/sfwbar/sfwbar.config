#Api2

# Toggle Logic
#define-state "tray-visible" {
#    toggle = true
#    value = false
#}

# Bind the action name to the toggle function
action "menu-toggle" {
    toggle-state "tray-visible"
}

# 1. Window Placer
placer {
    xorigin = 5
    yorigin = 5
    xstep = 5
    ystep = 5
    children = true
}

# 2. Main Layout
layout {
    # Taskbar (Expands to fill)
    grid {
        css = "* { -GtkWidget-hexpand: true; }"
        
        taskbar {
            rows = 1
            icons = true
            labels = true
            group = false
            sort = false
        }
    }

    # Tray Toggle Container
    grid {
        halign = "end"

        # The Toggle Button
        button {
            label = "^"
            action = "menu-toggle"
        }

        # The Tray (Hidden/Shown by the button)
        box "traybox" {
            visible = state("tray-visible")
            tray {
                rows = 1
            }
        }
    }
}
