#Api2

placer {
    xorigin = 5
    yorigin = 5
    xstep = 5
    ystep = 5
    children = true
}

layout {
    layer = "top"
    position = "bottom"

    grid ":start" {
        taskbar {
            rows = 1
            icons = true
            labels = true
            group = false
            sort = false
            style = "taskbar"
        }
    }

    grid ":end" {
        tray {
            rows = 1
        }
    }
}
