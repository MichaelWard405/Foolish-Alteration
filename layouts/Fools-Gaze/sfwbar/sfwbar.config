#Api2

placer {
    xorigin = 5
    yorigin = 5
    xstep = 5
    ystep = 5
    children = true
}

layout {
    # Forces the bar to the bottom of the screen
    layer = "top"
    position = "bottom"

    grid ":start" {
        taskbar {
            rows = 1
            icons = true
            labels = true
        }
    }

    grid ":end" {
        tray {
            rows = 1
        }
    }
}
