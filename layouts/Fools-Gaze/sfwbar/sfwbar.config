#Api2

include("winops.widget")

placer {
    xorigin = 5
    yorigin = 5
    xstep = 5
    ystep = 5
    children = true
}

layout {
    layer = "top"
    position = "bottom"

    taskbar {
        rows = 1
        css = "* { -GtkWidget-hexpand: true; }"
        labels = true
        icons = true
        group = false
        sort = false
        style = "taskbar"
    }

    tray {
        rows = 1
    }
}
