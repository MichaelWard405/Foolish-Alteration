#Api2

Set ThicknessHint = "20px"

# Defined PopUp drawer for system tray
PopUp "tray_popup" {
  AutoClose = true
  tray {
    rows = 1
  }
}

bar {
  edge = "bottom" 
  layer = "top"
  exclusive_zone = "auto"

  taskbar {
    style = "taskbar"
    rows = 1;
    tooltips = true;
    icons = true;
    labels = true;
    action[Drag] = Focus();
  }

  # Expander label to push buttons to the far right
  label {
    css = "* { -GtkWidget-hexpand: true; }"
  }

  # Python Script Pin Button
  button {
    type = "label"
    value = "^"
    action = Exec("kitty -e python3 ~/.local/share/Foolish-Alteration/Foolish_Alteration.py")
  }

  # Pop-up System Tray Button
  button {
    type = "label"
    value = "^"
    action = PopUp("tray_popup")
  }
}

#CSS
@import url("style.css");
