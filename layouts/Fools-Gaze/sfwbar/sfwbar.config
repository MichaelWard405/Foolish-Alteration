#Api2

Set ThicknessHint = "20px"

PopUp "tray_popup" {
  AutoClose = true
  tray {
    rows = 1
  }
}

bar {
  edge = "bottom" 
  layer = "top"
  exclusive_zone = "auto"

  taskbar {
    style = "taskbar"
    rows = 1;
    tooltips = true;
    icons = true;
    labels = true;
    action[Drag] = Focus();
  }

  label {
    css = "* { -GtkWidget-hexpand: true; }"
  }

  # Script execution button (Pin)
  # IMPORTANT: This command launches Kitty and runs your script.
  # If your primary script file is saved somewhere else, update the absolute path below!
  button {
    label = "^"
    action = Exec("kitty -e python3 ~/.local/share/Foolish-Alteration/Foolish_Alteration.py")
  }

  # Pop-out tray button
  button {
    label = "^"
    action = PopUp("tray_popup")
  }
}

#CSS
@import url("style.css");
