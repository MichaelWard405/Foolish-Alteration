#Api2

# 1. Window Placer
placer {
    xorigin = 5
    yorigin = 5
    xstep = 5
    ystep = 5
    children = true
}

# 2. Main Layout
layout {
    grid {
        css = "* { -GtkWidget-hexpand: true; }"
        
        taskbar {
            rows = 1
            icons = true
            labels = true
            group = false
            sort = false
        }
    }
}
