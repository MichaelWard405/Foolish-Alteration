{
    "layer": "top",
    "position": "top",
    "height": 34,
    "modules-left": ["sway/workspaces", "sway/window"],
    "modules-center": ["clock"],
    "modules-right": ["cpu", "memory", "network", "pulseaudio"],

    "sway/workspaces": {
        "disable-scroll": true,
        "all-outputs": true,
        "format": "[ {icon} ]",
        "format-icons": {
            "1": "I",
            "2": "II",
            "3": "III",
            "4": "IV",
            "5": "V",
            "urgent": "!",
            "focused": "*",
            "default": "_"
        }
    },
    "clock": {
        "format": "{:%I:%M %p  |  %a, %b %d}",
        "on-click": "zenity --calendar"
    },
    "cpu": {
        "format": "CPU: {usage}%",
        "on-click": "kitty -e btop"
    },
    "memory": {
        "format": "RAM: {}%",
        "on-click": "kitty -e btop"
    },
    "network": {
        "format-wifi": "WIFI: {essid}",
        "format-ethernet": "LAN: Connected",
        "format-disconnected": "Offline",
        "on-click": "kitty -e nmtui"
    },
    "pulseaudio": {
        "format": "VOL: {volume}%",
        "format-muted": "MUTED",
        "on-click": "pavucontrol"
    }
}
